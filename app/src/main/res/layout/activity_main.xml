<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F8FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:text="💧 "
                android:textSize="28sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Water Tracker"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Circular Progress -->
        <com.example.water.WaterCircleView
            android:id="@+id/waterCircleView"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_gravity="center"
            android:layout_marginBottom="15dp"/>

        <!-- ml text -->
        <TextView
            android:id="@+id/tvStatus"
            android:text="1300 ml / 2000 ml"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"/>

        <!-- Streak Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp"
            android:elevation="4dp">

            <TextView
                android:text="🔥 Streak: "
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF6F00"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvStreak"
                android:text="0 Days"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF6F00"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Quick Add Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">

            <Button
                android:id="@+id/btn100"
                android:text="+ 100 ml"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn250"
                android:text="+ 250 ml"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btn500"
                android:text="+ 500 ml"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Tip Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp"
            android:elevation="4dp">

            <TextView
                android:text="💡 Tip: "
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFA000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvTip"
                android:text="Drink a glass of water now!"
                android:textSize="14sp"
                android:textColor="#546E7A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>
        <EditText
            android:id="@+id/etAmount"
            android:hint="Enter custom amount (ml)"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="10dp"
            android:background="#FFFFFF"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:elevation="4dp"/>
        <!-- Add Water Button -->
        <Button
            android:id="@+id/btnAdd"
            android:text="+ Add Water"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="15dp"/>

        <!-- Bottom Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnHistory"
                android:text="📋 View History"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#E3F2FD"
                android:textColor="#1E88E5"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnReminder"
                android:text="⏰ Set Reminder"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:backgroundTint="#E3F2FD"
                android:textColor="#1E88E5"
                android:textSize="12sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSettings"
                android:text="⚙️ Settings"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#E3F2FD"
                android:textColor="#1E88E5"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnStats"
                android:text="📊 Statistics"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:backgroundTint="#E3F2FD"
                android:textColor="#1E88E5"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>